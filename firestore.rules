rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['pseudo', 'slots', 'rollState', 'role', 'isGm']) &&
        data.pseudo is string && data.pseudo.size() <= 50 &&
        data.role is string && data.role.size() <= 10 &&
        data.isGm is bool &&
        data.slots is string && data.slots.size() <= 1048576 &&
        data.rollState is string && data.rollState.size() <= 20 &&
        (
          !('rolledValue' in data.keys()) ||
          (data.rolledValue is number || data.rolledValue == null)
        );
    }

    function isValidGMState(data) {
      return data.keys().hasAll(['rollState', 'diceResult', 'checkedEncounters']) &&
        data.rollState is string && data.rollState.size() <= 20 &&
        data.diceResult is string && data.diceResult.size() <= 5000 &&
        data.checkedEncounters is string && data.checkedEncounters.size() <= 5000 &&
        (
          !('encounterRolls' in data.keys()) ||
          data.encounterRolls == null ||
          (data.encounterRolls is string && data.encounterRolls.size() <= 20000)
        ) &&
        (
          !('encounterLevel' in data.keys()) ||
          data.encounterLevel == null ||
          (data.encounterLevel is string && data.encounterLevel.size() <= 10)
        ) &&
        (
          !('pin' in data.keys()) ||
          data.pin == null ||
          (data.pin is string && data.pin.size() == 5)
        ) &&
        (
          !('gmNotes2' in data.keys()) ||
          data.gmNotes2 == null ||
          (data.gmNotes2 is string && data.gmNotes2.size() <= 1048576)
        );
    }

    match /{path=**}/players/{playerCode} {
      allow read: if true;
    }
    match /{path=**}/gm/{docId} {
      allow read: if true;
    }

    match /rooms/{roomId}/players/{playerCode} {
      allow read, list: if true;
      allow create: if isValidId(roomId) && isValidId(playerCode) && playerCode.size() == 5 &&
                    isValidPlayer(incoming());
      
      allow update: if isValidId(roomId) && isValidId(playerCode) && playerCode.size() == 5 &&
                    isValidPlayer(incoming());
      
      allow delete: if isValidId(roomId) && isValidId(playerCode);
    }
    
    match /rooms/{roomId}/gm/state {
      allow read, list: if true;
      allow create: if isValidId(roomId) && isValidGMState(incoming()) && incoming().keys().size() <= 7;
      allow update: if isValidId(roomId) && isValidGMState(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['rollState', 'diceResult', 'checkedEncounters', 'encounterRolls', 'encounterLevel', 'pin', 'gmNotes2']);
      allow delete: if isValidId(roomId);
    }
  }
}
