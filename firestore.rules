rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY WARNING: Currently, these rules allow anyone to read/write 
    // to your database if they know the project ID.
    // 
    // To secure your database, you MUST implement Firebase Authentication 
    // and change the rules below to require authentication:
    //
    // match /{document=**} {
    //   allow read, write: if request.auth != null;
    // }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
